     SYNTIfood — Menú Digital + Pedido WhatsApp
     Preline 4.1.2 · Tailwind v4 · Alpine.js 3.4.2
     SCROLL BUG FIX: CERO overflow-hidden en contenedores padre
═══════════════════════════════════════════════════════════════════════════════ --}}
@extends('landing.base')

@php
    $savedDisplayMode = $savedDisplayMode ?? $displayMode ?? 'reference_only';
    $currencySymbol   = $currencySettings['symbols']['reference'] ?? 'REF';
    $dollarRate        = $dollarRate ?? 36.50;
    $euroRate          = $euroRate ?? 495.00;
    $hidePrice         = $hidePrice ?? false;

    $wa      = $tenant->getActiveWhatsapp() ?? null;
    $waClean = $wa ? preg_replace('/[^0-9]/', '', $wa) : '';

    $categories  = $menu ?? [];
    $plan        = $tenant->plan ?? null;
    $isPlanAnual = $plan && (in_array($plan->slug ?? '', ['food-anual']) || ($plan->id ?? 0) >= 3);

    $customerFields = $customization->customer_required_fields
        ?? ($tenant->settings['food_settings']['customer_fields'] ?? ['name']);
    $needsName = in_array('name', (array) $customerFields);

    $heroImages = array_values(array_filter([
        $customization->hero_image ?? null,
        $customization->hero_image_2 ?? null,
        $customization->hero_image_3 ?? null,
    ]));

    $activeCats = [];
    foreach ($categories as $catIdx => $cat) {
        if (empty($cat['activo'])) continue;
        $activeItems = array_values(array_filter($cat['items'] ?? [], fn($i) => !empty($i['activo'])));
        if (count($activeItems) === 0) continue;
        $activeCats[] = array_merge($cat, [
            '_index' => $catIdx,
            '_items' => $activeItems,
        ]);
    }
@endphp

@push('styles')
<style>
    .sf-no-scrollbar::-webkit-scrollbar { display: none }
    .sf-no-scrollbar { -ms-overflow-style: none; scrollbar-width: none }
    .sf-hero-slide { transition: opacity 800ms ease-in-out }
    @keyframes sf-bounce { 0%,100%{transform:scale(1)} 50%{transform:scale(1.25)} }
    .sf-bounce { animation: sf-bounce .6s ease }
    @keyframes sf-pulse { 0%,100%{opacity:1} 50%{opacity:.4} }
    .sf-pulse { animation: sf-pulse 2s ease-in-out infinite }
    .sf-drawer-t { transition: transform 300ms cubic-bezier(.4,0,.2,1) }
    [x-cloak] { display: none !important }
</style>
@endpush

@section('content')
<div x-data="sfApp()" x-init="initApp()" x-cloak class="min-h-screen flex flex-col">

