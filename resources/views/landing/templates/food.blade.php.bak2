{{-- ═══════════════════════════════════════════════════════════════════════════
     SCRIPTS — Alpine component + IntersectionObserver + Analytics
═══════════════════════════════════════════════════════════════════════════════ --}}
@push('scripts')
<script>
function sfApp() {
    const CURRENCY_MODE   = @json($savedDisplayMode);
    const CURRENCY_SYMBOL = @json($currencySymbol);
    const EXCHANGE_RATE   = @json($dollarRate);
    const EURO_RATE       = @json($euroRate);
    const WA_NUMBER       = @json($waClean);
    const BIZ_NAME        = @json($tenant->business_name);
    const SUBDOMAIN       = @json($tenant->subdomain);
    const IS_PLAN_CART    = @json($isPlanAnual);
    const NEEDS_NAME      = @json($needsName);
    const HERO_TOTAL      = {{ count($heroImages) }};

    return {
        heroSlide: 0,
        heroTimer: null,
        infoModal: false,
        productModal: false,
        selectedProduct: null,
        productQty: 1,
        drawerOpen: false,
        dataModal: false,
        searchOpen: false,
        searchQuery: '',
        catDropdown: false,
        activeCategory: 0,
        customerName: localStorage.getItem('sf_customer_name') || '',
        modalidad: 'sitio',
        nameError: false,
        cart: [],
        currentCurrency: (CURRENCY_MODE === 'bolivares_only') ? 'bs' : 'ref',

        get currencyLabel() {
            return this.currentCurrency === 'bs' ? 'Bs.' : CURRENCY_SYMBOL;
        },
        get cartCount() {
            return this.cart.reduce(function(s, i) { return s + i.qty; }, 0);
        },
        get cartTotal() {
            return this.cart.reduce(function(s, i) { return s + (i.price * i.qty); }, 0);
        },

        fmtVal(usd) {
            var val = parseFloat(usd) || 0;
            var rate = this.currentCurrency === 'bs' ? EXCHANGE_RATE : 1;
            return (val * rate).toLocaleString('es-VE', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        },

        fmtPlain(usd) {
            var label = this.currentCurrency === 'bs' ? 'Bs.' : CURRENCY_SYMBOL;
            return label + ' ' + this.fmtVal(usd);
        },

        initApp() {
            var self = this;

            // Hero slider auto-play
            if (HERO_TOTAL > 1) {
                this.heroTimer = setInterval(function() {
                    self.heroSlide = (self.heroSlide + 1) % HERO_TOTAL;
                }, 5000);
            }

            // IntersectionObserver para scroll-spy de categorías
            this.$nextTick(function() {
                var sections = document.querySelectorAll('[data-category-section]');
                if (sections.length < 2) return;

                var observer = new IntersectionObserver(function(entries) {
                    entries.forEach(function(entry) {
                        if (entry.isIntersecting) {
                            var idx = parseInt(entry.target.dataset.categorySection);
                            self.activeCategory = idx;
                        }
                    });
                }, { threshold: 0.3, rootMargin: '-80px 0px -60% 0px' });

                sections.forEach(function(el) { observer.observe(el); });

                // Indicador inicial
                self.moveIndicator(0);
            });

            // Watch activeCategory para mover indicador
            this.$watch('activeCategory', function(val) {
                self.moveIndicator(val);
            });
        },

        // ── Categorías ──────────────────────────────────────────
        scrollToCategory(domIdx, tabIdx) {
            var el = document.getElementById('sf-cat-' + domIdx);
            if (!el) return;
            var bar = this.$refs.stickyBar;
            var offset = bar ? bar.offsetHeight : 120;
            var top = el.getBoundingClientRect().top + window.scrollY - offset - 12;
            window.scrollTo({ top: top, behavior: 'smooth' });
            this.activeCategory = tabIdx;
            this.catDropdown = false;
        },

        moveIndicator(idx) {
            var self = this;
            this.$nextTick(function() {
                var tab = self.$refs['catTab' + idx];
                var indicator = self.$refs.catIndicator;
                if (!tab || !indicator) return;
                indicator.style.left = tab.offsetLeft + 'px';
                indicator.style.width = tab.offsetWidth + 'px';
                tab.scrollIntoView({ block: 'nearest', inline: 'center', behavior: 'smooth' });
            });
        },

        // ── Búsqueda ────────────────────────────────────────────
        filterProducts() {
            var q = this.searchQuery.toLowerCase().trim();
            document.querySelectorAll('[data-item-name]').forEach(function(card) {
                card.style.display = (q && card.dataset.itemName.indexOf(q) === -1) ? 'none' : '';
            });
            document.querySelectorAll('[data-category-section]').forEach(function(section) {
                var visible = section.querySelectorAll('[data-item-name]:not([style*="display: none"])');
                section.style.display = (q && visible.length === 0) ? 'none' : '';
            });
        },

        // ── Moneda ──────────────────────────────────────────────
        setCurrency(mode) {
            this.currentCurrency = mode;
        },

        // ── Producto modal ──────────────────────────────────────
        openProduct(item) {
            this.selectedProduct = item;
            this.productQty = 1;
            this.productModal = true;
        },

        closeProduct() {
            this.productModal = false;
            this.selectedProduct = null;
        },

        // ── Carrito ─────────────────────────────────────────────
        addToCart() {
            if (!this.selectedProduct || !IS_PLAN_CART) return;
            var id = this.selectedProduct.id || '';
            var existing = this.cart.find(function(i) { return i.id === id; });
            if (existing) {
                existing.qty += this.productQty;
            } else {
                this.cart.push({
                    id: id,
                    name: this.selectedProduct.nombre || '',
                    price: parseFloat(this.selectedProduct.precio) || 0,
                    image: this.selectedProduct.image_path || '',
                    qty: this.productQty
                });
            }
            this.closeProduct();
            // Bounce badge
            var badge = this.$refs.cartBadge;
            if (badge) {
                badge.classList.remove('sf-bounce');
                void badge.offsetWidth;
                badge.classList.add('sf-bounce');
            }
        },

        changeCartQty(idx, delta) {
            if (!this.cart[idx]) return;
            this.cart[idx].qty += delta;
            if (this.cart[idx].qty <= 0) {
                this.cart.splice(idx, 1);
            }
        },

        // ── Drawer ──────────────────────────────────────────────
        openDrawer() {
            this.drawerOpen = true;
            document.body.style.overflow = 'hidden';
        },

        closeDrawer() {
            this.drawerOpen = false;
            document.body.style.overflow = '';
        },

        // ── WhatsApp checkout ───────────────────────────────────
        sendWhatsApp() {
            this.dataModal = true;
        },

        async confirmAndSend() {
            var name = this.customerName.trim();

            if (NEEDS_NAME && !name) {
                this.nameError = true;
                return;
            }

            if (name) localStorage.setItem('sf_customer_name', name);
            this.dataModal = false;

            var cartItems = this.cart.map(function(i) {
                return { nombre: i.name, qty: i.qty, precio: i.price };
            });

            // Intentar API de checkout primero
            try {
                var res = await fetch('/' + SUBDOMAIN + '/food-checkout', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': document.querySelector('meta[name="csrf-token"]').content
                    },
                    body: JSON.stringify({
                        customer_name: name || '',
                        modalidad: this.modalidad,
                        items: cartItems
                    })
                });
                var data = await res.json();
                if (data.success && data.whatsapp_url) {
                    window.open(data.whatsapp_url, '_blank');
                    this.cart = [];
                    this.closeDrawer();
                    return;
                }
            } catch(e) {
                console.error('Checkout error:', e);
            }

            // Fallback: mensaje directo por WhatsApp
            if (!WA_NUMBER) return;
            var self = this;
            var modLabels = { sitio: 'Comer en sitio', llevar: 'Para llevar', delivery: 'Delivery' };
            var greeting = name
                ? '\uD83C\uDF7D ¡Hola! Soy *' + name + '* y vengo de la web de *' + BIZ_NAME + '*'
                : '\uD83C\uDF7D ¡Hola! Les escribo desde la web de *' + BIZ_NAME + '*';
            var items = this.cart.map(function(i) {
                return '• ' + i.name + ' ×' + i.qty + ' (' + self.fmtPlain(i.price * i.qty) + ')';
            }).join('\n');
            var msg = greeting + '\n\n*Mi pedido:*\n' + items;
            msg += '\n\n*Total: ' + this.fmtPlain(this.cartTotal) + '*';
            msg += '\nModalidad: ' + (modLabels[this.modalidad] || this.modalidad);
            window.open('https://wa.me/' + WA_NUMBER + '?text=' + encodeURIComponent(msg), '_blank');
            this.cart = [];
            this.closeDrawer();
        },

        // ── Compartir ───────────────────────────────────────────
        shareStore() {
            if (navigator.share) {
                navigator.share({
                    title: BIZ_NAME,
                    text: 'Mira el menú de ' + BIZ_NAME,
                    url: window.location.href
                }).catch(function() {});
            } else {
                navigator.clipboard.writeText(window.location.href).then(function() {
                    alert('Enlace copiado');
                }).catch(function() {});
            }
        },

        // ── Utils ───────────────────────────────────────────────
        closeAll() {
            if (this.productModal) { this.closeProduct(); return; }
            if (this.infoModal) { this.infoModal = false; return; }
            if (this.dataModal) { this.dataModal = false; return; }
            if (this.drawerOpen) { this.closeDrawer(); return; }
            if (this.searchOpen) { this.searchOpen = false; this.searchQuery = ''; this.filterProducts(); return; }
            if (this.catDropdown) { this.catDropdown = false; return; }
        }
    };
}
</script>

{{-- SyntiTrack Analytics --}}
<script>
(function() {
    'use strict';
    var TID = {{ $tenant->id }};
    var CSRF = document.querySelector('meta[name="csrf-token"]')?.content ?? '';
    function track(type) {
        fetch('/api/analytics/track', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': CSRF },
            body: JSON.stringify({ tenant_id: TID, event_type: type })
        }).catch(function() {});
    }
    track('pageview');
    document.addEventListener('click', function(e) {
        if (e.target.closest('a[href*="wa.me"]')) track('click_whatsapp');
        if (e.target.closest('a[href^="tel:"]')) track('click_call');
    });
    setInterval(function() { track('time_on_page'); }, 30000);
})();
</script>
@endpush
