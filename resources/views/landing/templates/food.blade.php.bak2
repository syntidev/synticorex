═══════════════════════════════════════════════════════════════════════════════ --}}
@if(count($heroImages) > 0)
<div class="relative w-full overflow-hidden" style="height:220px">
    @foreach($heroImages as $hIdx => $hImg)
    <div class="sf-hero-slide absolute inset-0" :style="{ opacity: heroSlide === {{ $hIdx }} ? '1' : '0' }">
        <img src="/storage/{{ $hImg }}" alt="{{ $tenant->business_name }}" class="w-full h-full object-cover" @if($hIdx > 0) loading="lazy" @endif>
    </div>
    @endforeach
    <div class="absolute inset-0 bg-linear-to-t from-black/40 via-transparent to-transparent pointer-events-none"></div>
    @if(count($heroImages) > 1)
    <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-2 z-10">
        @foreach($heroImages as $hIdx => $hImg)
        <button @click="heroSlide = {{ $hIdx }}" class="rounded-full transition-all duration-300 cursor-pointer"
                :class="heroSlide === {{ $hIdx }} ? 'w-6 h-2 bg-white' : 'w-2 h-2 bg-white/50'"></button>
        @endforeach
    </div>
    @endif
</div>
@endif

