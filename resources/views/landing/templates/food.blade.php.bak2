{{-- ═══════════════════════════════════════════════════════════════════════════
     9. DRAWER DEL PEDIDO — fixed right, z-[90]
═══════════════════════════════════════════════════════════════════════════════ --}}
{{-- Overlay --}}
<div x-show="drawerOpen" x-cloak @click="closeDrawer()"
     x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
     x-transition:leave="transition ease-in duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
     class="fixed inset-0 z-80 backdrop-blur-sm" style="background:rgba(0,0,0,.5)"></div>

{{-- Panel --}}
<aside class="fixed inset-y-0 right-0 z-90 w-full max-w-sm bg-white shadow-2xl sf-drawer-t flex flex-col"
       :class="drawerOpen ? 'translate-x-0' : 'translate-x-full'">

    {{-- Header --}}
    <div class="px-6 pt-6 pb-4 flex items-center justify-between border-b border-gray-100 shrink-0">
        <div>
            <h3 class="text-xl font-bold tracking-tight text-gray-900">Tu pedido</h3>
            <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest mt-0.5">Resumen</p>
        </div>
        <button @click="closeDrawer()" class="p-2 rounded-full text-gray-400 hover:bg-gray-100 transition-colors cursor-pointer">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
    </div>

    {{-- Empty state --}}
    <div x-show="cartCount === 0" class="flex-1 flex flex-col items-center justify-center text-center py-14 px-6">
        <div class="w-16 h-16 rounded-2xl bg-gray-100 flex items-center justify-center mb-4">
            <svg class="w-8 h-8 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
        </div>
        <p class="font-semibold text-gray-400">Tu pedido está vacío</p>
        <p class="text-xs text-gray-300 mt-1">Explora el menú y agrega platos</p>
    </div>

    {{-- Items list --}}
    <div x-show="cartCount > 0" class="flex-1 overflow-y-auto px-6 py-4 space-y-0">
        <template x-for="(item, idx) in cart" :key="idx">
            <div class="flex items-center gap-3 py-4 border-b border-gray-50 last:border-0">
                <div class="w-12 h-12 rounded-xl bg-gray-100 shrink-0 overflow-hidden">
                    <template x-if="item.image">
                        <img :src="'/storage/' + item.image" :alt="item.name" class="w-full h-full object-cover">
                    </template>
                    <template x-if="!item.image">
                        <div class="w-full h-full flex items-center justify-center">
                            <svg class="w-5 h-5 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 8h1a4 4 0 010 8h-1M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8zM6 1v3M10 1v3M14 1v3"/></svg>
                        </div>
                    </template>
                </div>
                <div class="flex-1 min-w-0">
                    <p x-text="item.name" class="text-sm font-semibold text-gray-900 truncate"></p>
                    <p class="text-xs text-gray-400 font-medium">
                        <span x-text="item.qty"></span> × <span x-text="currencyLabel"></span> <span x-text="fmtVal(item.price)"></span>
                    </p>
                </div>
                <div class="flex items-center gap-1.5 shrink-0">
                    <button @click="changeCartQty(idx, -1)" class="w-7 h-7 rounded-full border border-gray-200 flex items-center justify-center text-sm font-bold text-gray-600 hover:bg-gray-50 transition-colors cursor-pointer">−</button>
                    <span x-text="item.qty" class="text-sm font-bold min-w-4 text-center"></span>
                    <button @click="changeCartQty(idx, 1)" class="w-7 h-7 rounded-full flex items-center justify-center text-sm font-bold text-white cursor-pointer" style="background:var(--primary, #2563eb)">+</button>
                </div>
            </div>
        </template>
    </div>

    {{-- Footer --}}
    <div x-show="cartCount > 0" class="p-6 border-t border-gray-100 space-y-4 shrink-0">
        <div class="bg-gray-50 rounded-2xl p-4">
            <div class="flex justify-between items-center text-gray-400 text-xs font-bold uppercase tracking-widest mb-1">
                <span>Total</span>
                <span x-text="currencyLabel"></span>
            </div>
            <div class="text-3xl font-bold tracking-tight text-gray-900" x-text="fmtVal(cartTotal)"></div>
        </div>
        @if($waClean)
        <button @click="sendWhatsApp()"
                class="flex items-center justify-center w-full h-14 rounded-2xl font-bold text-base gap-2.5 shadow-lg text-white transition-opacity hover:opacity-90 cursor-pointer" style="background:#25D366">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Enviar por WhatsApp
        </button>
        @endif
    </div>
</aside>

{{-- ═══════════════════════════════════════════════════════════════════════════
     10. MODAL DATOS CLIENTE — antes de enviar pedido
═══════════════════════════════════════════════════════════════════════════════ --}}
<div x-show="dataModal" x-cloak
     x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
     x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
     class="fixed inset-0 z-100 flex items-center justify-center p-4" style="background:rgba(0,0,0,.5)"
     @click.self="dataModal = false">
    <div x-show="dataModal"
         x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 scale-95" x-transition:enter-end="opacity-100 scale-100"
         x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100 scale-100" x-transition:leave-end="opacity-0 scale-95"
         class="bg-white rounded-2xl max-w-sm w-full p-6 shadow-2xl space-y-5">

        <div class="flex items-start gap-3">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background:color-mix(in oklch, var(--primary, #2563eb) 10%, transparent)">
                <svg class="w-5 h-5" style="color:var(--primary, #2563eb)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="7" r="4"/><path d="M5.5 21a6.5 6.5 0 0113 0"/></svg>
            </div>
            <div class="flex-1">
                <p class="text-lg font-bold text-gray-900">Antes de enviar</p>
                <p class="text-sm text-gray-500">Déjanos tus datos para el pedido.</p>
            </div>
            <button @click="dataModal = false" class="p-1.5 rounded-full text-gray-400 hover:bg-gray-100 transition-colors cursor-pointer">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>

        @if($needsName)
        <div class="relative">
            <input x-model="customerName" type="text" id="sf-cname" placeholder=" " autocomplete="given-name"
                   class="w-full px-4 pt-5 pb-2 rounded-xl border border-gray-200 bg-gray-50 text-sm font-semibold outline-none transition-all focus:border-blue-400 focus:bg-white focus:ring-2 focus:ring-blue-100 peer"
                   :class="nameError ? 'border-red-400 bg-red-50 focus:ring-red-100' : ''"
                   @input="nameError = false">
            <label for="sf-cname" class="absolute left-4 top-1/2 -translate-y-1/2 text-sm text-gray-400 pointer-events-none transition-all peer-focus:top-2.5 peer-focus:translate-y-0 peer-focus:text-[10px] peer-focus:font-bold peer-focus:tracking-wider peer-[:not(:placeholder-shown)]:top-2.5 peer-[:not(:placeholder-shown)]:translate-y-0 peer-[:not(:placeholder-shown)]:text-[10px] peer-[:not(:placeholder-shown)]:font-bold peer-[:not(:placeholder-shown)]:tracking-wider" style="color:var(--primary, #2563eb)">
                ¿Cómo te llamas?
            </label>
        </div>
        @endif

        <div class="space-y-2">
            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Modalidad</p>
            <div class="grid grid-cols-3 gap-2">
                <label class="flex items-center gap-2 cursor-pointer rounded-xl border border-gray-200 px-3 py-2.5 transition-colors has-checked:border-blue-500 has-checked:bg-blue-50">
                    <input x-model="modalidad" type="radio" name="sf-mod" value="sitio" class="accent-blue-600">
                    <span class="text-xs font-semibold text-gray-700">En sitio</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer rounded-xl border border-gray-200 px-3 py-2.5 transition-colors has-checked:border-blue-500 has-checked:bg-blue-50">
                    <input x-model="modalidad" type="radio" name="sf-mod" value="llevar" class="accent-blue-600">
                    <span class="text-xs font-semibold text-gray-700">Llevar</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer rounded-xl border border-gray-200 px-3 py-2.5 transition-colors has-checked:border-blue-500 has-checked:bg-blue-50">
                    <input x-model="modalidad" type="radio" name="sf-mod" value="delivery" class="accent-blue-600">
                    <span class="text-xs font-semibold text-gray-700">Delivery</span>
                </label>
            </div>
        </div>

        <div class="flex gap-3 pt-1">
            <button @click="confirmAndSend()" class="flex-1 py-3 px-4 rounded-xl font-bold text-sm text-white transition-opacity hover:opacity-90 cursor-pointer" style="background:var(--primary, #2563eb)">
                Enviar por WhatsApp
            </button>
            <button @click="dataModal = false" class="py-3 px-4 rounded-xl font-medium text-sm text-gray-600 hover:bg-gray-100 transition-colors cursor-pointer">
                Cancelar
            </button>
        </div>
    </div>
</div>
@endif

